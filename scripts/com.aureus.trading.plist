  <!-- ─── Resource limits ───────────────────────────────────────────────── -->
  <!-- Throttle restart: wait 60s before restarting on crash -->
  <key>ThrottleInterval</key>
  <integer>60</integer>

  <!-- ─── Environment ───────────────────────────────────────────────────── -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/doctorboyz/EA/venv/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
  </dict>

</dict>
</plist>
