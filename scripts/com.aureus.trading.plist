<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- ─── Identity ─────────────────────────────────────────────────────── -->
  <key>Label</key>
  <string>com.aureus.trading</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/doctorboyz/EA/venv/bin/python</string>
    <string>/Users/doctorboyz/EA/scripts/run_multi.py</string>
    <string>--symbols</string>
    <string>XAUUSD</string>
    <string>--continuous</string>
    <string>--iterations</string>
    <string>30</string>
    <string>--restart-delay</string>
    <string>300</string>
  </array>

  <!-- ─── Working directory ────────────────────────────────────────────── -->
  <key>WorkingDirectory</key>
  <string>/Users/doctorboyz/EA</string>

  <!-- ─── Logging ──────────────────────────────────────────────────────── -->
  <key>StandardOutPath</key>
  <string>/Users/doctorboyz/EA/logs/launchagent_stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/doctorboyz/EA/logs/launchagent_stderr.log</string>

