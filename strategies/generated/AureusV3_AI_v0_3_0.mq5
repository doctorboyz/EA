//+------------------------------------------------------------------+
//|  AureusV3_AI.mq5                                                   |
//|  Generated by Aureus AI — Version 0.3.0                  |
//|  EURUSD H1 | Risk: 1.0% per trade |
//+------------------------------------------------------------------+
#property copyright "Copyright 2026, Aureus Trading"
#property version   "0.3.0"
#property strict

//--- Inputs
input int      MagicNumber       = 20260400;
input double   RiskPercent       = 1.0;      // % of balance per trade (NEVER fixed USD)
input double   MaxSpreadPips     = 2.0;   // Skip entry if spread exceeds this
input int      StopLossPips      = 30;    // Stop loss distance in pips
input int      TakeProfitPips    = 90;  // Take profit distance in pips
input int      BreakEvenPips     = 15;    // Move SL to BE when profit >= this
input int      TrailingStopPips  = 20; // Trailing stop distance in pips

//--- Indicator Inputs
input int      RSI_Period        = 14;
input double   RSI_Oversold      = 30.0;      // Buy signal RSI threshold
input double   RSI_Overbought    = 70.0;    // Sell signal RSI threshold
input int      ATR_Period        = 14;
input double   ATR_MaxMultiplier = 1.5; // Skip if ATR > avg * this multiplier
input int      EMA_Period        = 200;         // Trend filter: buy above, sell below
input int      LookbackPeriod    = 120;    // Structural high/low lookback bars


//--- Global Handles
int handleRSI  = INVALID_HANDLE;
int handleATR  = INVALID_HANDLE;
int handleEMA  = INVALID_HANDLE;

//--- State Variables
datetime lastTradeBar   = 0;
datetime lastModifyTime = 0;
double   atrBaseline    = 0.0;   // Rolling ATR average for dynamic filter

//+------------------------------------------------------------------+
//| Expert initialization                                             |
//+------------------------------------------------------------------+
int OnInit()
{
   handleRSI = iRSI(_Symbol, _Period, RSI_Period, PRICE_CLOSE);
   handleATR = iATR(_Symbol, _Period, ATR_Period);
   handleEMA = iMA(_Symbol, _Period, EMA_Period, 0, MODE_EMA, PRICE_CLOSE);

   bool allValid = (handleRSI != INVALID_HANDLE &&
                    handleATR != INVALID_HANDLE &&
                    handleEMA != INVALID_HANDLE
                   );

   if(!allValid) {
      Print("[AureusV3_AI] ERROR: Failed to create indicator handles");
      return INIT_FAILED;
   }

   Print("[AureusV3_AI] v0.3.0 initialized | Risk:", RiskPercent,
         "% | SL:", StopLossPips, " TP:", TakeProfitPips);
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| Expert deinitialization                                           |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   IndicatorRelease(handleRSI);
   IndicatorRelease(handleATR);
   IndicatorRelease(handleEMA);
   Comment("");
}

//+------------------------------------------------------------------+
//| Main tick handler                                                 |
//+------------------------------------------------------------------+
void OnTick()
{
   //--- Read indicator buffers
   double rsiVal[], atrVal[], emaVal[];
   ArraySetAsSeries(rsiVal, true);
   ArraySetAsSeries(atrVal, true);
   ArraySetAsSeries(emaVal, true);

   if(CopyBuffer(handleRSI, 0, 0, 2, rsiVal) < 2) return;
   if(CopyBuffer(handleATR, 0, 0, 3, atrVal) < 3) return;
   if(CopyBuffer(handleEMA, 0, 0, 1, emaVal) < 1) return;

   double currentRSI  = rsiVal[0];
   double currentATR  = atrVal[0];
   double currentEMA  = emaVal[0];
   double closePrice  = iClose(_Symbol, _Period, 0);
   double currentSpread = (double)SymbolInfoInteger(_Symbol, SYMBOL_SPREAD) / 10.0;


   //--- Update ATR baseline (simple 3-bar average)
   if(atrBaseline == 0.0) atrBaseline = atrVal[0];
   atrBaseline = (atrBaseline * 2.0 + atrVal[0]) / 3.0;

   //--- Display dashboard
   string trendDir = (closePrice > currentEMA) ? "BULL" : "BEAR";
   Comment("=== AureusV3_AI v0.3.0 ===\n"
           "Trend: " + trendDir + " (EMA" + IntegerToString(EMA_Period) + ")\n"
           "RSI: " + DoubleToString(currentRSI, 1) + "\n"
           "ATR: " + DoubleToString(currentATR, 5) +
           " (limit: " + DoubleToString(atrBaseline * ATR_MaxMultiplier, 5) + ")\n"
           "Spread: " + DoubleToString(currentSpread, 1) + " pips");

   //--- Position management (throttled to once per 3 seconds)
   if(TimeCurrent() - lastModifyTime >= 3) ManagePositions();
   CheckForEarlyExit(currentRSI);

   //--- Entry conditions
   if(PositionsTotal() > 0) return;
   if(currentSpread > MaxSpreadPips) return;

   //--- ATR volatility filter (skip chaotic candles)
   if(currentATR > atrBaseline * ATR_MaxMultiplier) return;


   //--- New bar check (one trade per bar)
   datetime currentBar = (datetime)SeriesInfoInteger(_Symbol, _Period, SERIES_LASTBAR_DATE);
   if(currentBar == lastTradeBar) return;

   //--- Structural extremes (N-bar high/low)
   int  lowIdx  = iLowest(_Symbol, _Period, MODE_LOW,  LookbackPeriod, 1);
   int  highIdx = iHighest(_Symbol, _Period, MODE_HIGH, LookbackPeriod, 1);
   double structuralLow  = iLow(_Symbol, _Period, lowIdx);
   double structuralHigh = iHigh(_Symbol, _Period, highIdx);
   double buffer = 5.0 * 10.0 * _Point;


   //--- BUY signal: above EMA (bullish trend) + near structural low + RSI oversold
   bool buySignal = (closePrice > currentEMA)
                 && (closePrice <= structuralLow + buffer)
                 && (currentRSI < RSI_Oversold)
                 ;

   //--- SELL signal: below EMA (bearish trend) + near structural high + RSI overbought
   bool sellSignal = (closePrice < currentEMA)
                  && (closePrice >= structuralHigh - buffer)
                  && (currentRSI > RSI_Overbought)
                  ;

   if(buySignal)       ExecuteTrade(ORDER_TYPE_BUY);
   else if(sellSignal) ExecuteTrade(ORDER_TYPE_SELL);
}

//+------------------------------------------------------------------+
//| RISK MANAGEMENT — Always percentage-based (NEVER fixed USD)      |
//+------------------------------------------------------------------+
double CalculateLotSize()
{
   double balance      = AccountInfoDouble(ACCOUNT_BALANCE);
   double freeMargin   = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
   double tickValue    = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);

   //--- Percentage risk calculation (V4 GUARD: this must never be a fixed amount)
   double lot = (balance * (RiskPercent / 100.0)) / (StopLossPips * 10.0 * tickValue);

   //--- Margin safety check
   double marginPerLot = 0.0;
   if(!OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, 1.0,
                       SymbolInfoDouble(_Symbol, SYMBOL_ASK), marginPerLot))
      marginPerLot = 250.0;

   if(marginPerLot > 0.0) {
      double maxLot = (freeMargin * 0.90) / marginPerLot;
      if(lot > maxLot) lot = maxLot;
   }

   //--- Normalize to broker volume step
   double stepL = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   double minL  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxL  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);

   lot = MathFloor(lot / stepL) * stepL;
   if(lot < minL) lot = minL;
   if(lot > maxL) lot = maxL;

   //--- Final margin check before returning
   double marginNeeded = 0.0;
   if(!OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, lot,
                       SymbolInfoDouble(_Symbol, SYMBOL_ASK), marginNeeded)
      || marginNeeded > freeMargin)
      return 0.0;

   return lot;
}

//+------------------------------------------------------------------+
//| Execute a market order                                            |
//+------------------------------------------------------------------+
void ExecuteTrade(ENUM_ORDER_TYPE orderType)
{
   double lot = CalculateLotSize();
   if(lot <= 0.0) {
      Print("[AureusV3_AI] Lot calculation returned 0 — skipping trade");
      return;
   }

   MqlTradeRequest req = {};
   MqlTradeResult  res = {};

   req.action        = TRADE_ACTION_DEAL;
   req.symbol        = _Symbol;
   req.volume        = lot;
   req.magic         = MagicNumber;
   req.type          = orderType;
   req.type_filling  = GetFillingMode();
   req.deviation     = 10;

   if(orderType == ORDER_TYPE_BUY) {
      req.price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      req.sl    = NormalizeDouble(req.price - (StopLossPips  * 10.0 * _Point), _Digits);
      req.tp    = NormalizeDouble(req.price + (TakeProfitPips * 10.0 * _Point), _Digits);
   } else {
      req.price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      req.sl    = NormalizeDouble(req.price + (StopLossPips  * 10.0 * _Point), _Digits);
      req.tp    = NormalizeDouble(req.price - (TakeProfitPips * 10.0 * _Point), _Digits);
   }

   if(!OrderSend(req, res))
      Print("[AureusV3_AI] Trade failed: retcode=", res.retcode);
   else {
      lastTradeBar = (datetime)SeriesInfoInteger(_Symbol, _Period, SERIES_LASTBAR_DATE);
      Print("[AureusV3_AI] Trade opened: ", EnumToString(orderType),
            " lot=", DoubleToString(lot, 2), " SL=", req.sl, " TP=", req.tp);
   }
}

//+------------------------------------------------------------------+
//| Position management: breakeven + trailing stop                   |
//+------------------------------------------------------------------+
void ManagePositions()
{
   double stopLevel  = (double)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL) * _Point;
   double freezeLevel = (double)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL) * _Point;
   double minDist    = stopLevel + (2.0 * 10.0 * _Point);

   for(int i = PositionsTotal() - 1; i >= 0; i--) {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;

      double openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
      double currentSL = PositionGetDouble(POSITION_SL);
      double currentTP = PositionGetDouble(POSITION_TP);
      double bid       = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double ask       = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double newSL     = currentSL;
      bool   doModify  = false;

      //--- Skip if near freeze level
      if(MathAbs(bid - currentSL) <= freezeLevel) continue;
      if(MathAbs(bid - currentTP) <= freezeLevel) continue;

      if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) {
         //--- Move to breakeven
         if(bid >= openPrice + (BreakEvenPips * 10.0 * _Point) && currentSL < openPrice)
            newSL = openPrice + (2.0 * 10.0 * _Point);
         //--- Trail
         double trail = NormalizeDouble(bid - (TrailingStopPips * 10.0 * _Point), _Digits);
         if(trail > newSL + (3.0 * 10.0 * _Point)) newSL = trail;
         if(newSL > currentSL + _Point && bid > newSL + minDist) doModify = true;

      } else { // SELL
         //--- Move to breakeven
         if(ask <= openPrice - (BreakEvenPips * 10.0 * _Point) &&
            (currentSL > openPrice || currentSL == 0.0))
            newSL = openPrice - (2.0 * 10.0 * _Point);
         //--- Trail
         double trail = NormalizeDouble(ask + (TrailingStopPips * 10.0 * _Point), _Digits);
         if(trail < newSL - (3.0 * 10.0 * _Point) || newSL == 0.0) newSL = trail;
         if((newSL < currentSL || currentSL == 0.0) && ask < newSL - minDist) doModify = true;
      }

      if(doModify) {
         MqlTradeRequest req = {};
         MqlTradeResult  res = {};
         req.action   = TRADE_ACTION_SLTP;
         req.position = ticket;
         req.symbol   = _Symbol;
         req.sl       = NormalizeDouble(newSL, _Digits);
         req.tp       = currentTP;
         if(OrderSend(req, res)) lastModifyTime = TimeCurrent();
      }
   }
}

//+------------------------------------------------------------------+
//| RSI early exit: close position when RSI reverses (if in profit)  |
//+------------------------------------------------------------------+
void CheckForEarlyExit(double rsi)
{
   for(int i = PositionsTotal() - 1; i >= 0; i--) {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;

      long   posType    = PositionGetInteger(POSITION_TYPE);
      double openPrice  = PositionGetDouble(POSITION_PRICE_OPEN);
      double curPrice   = (posType == POSITION_TYPE_BUY)
                          ? SymbolInfoDouble(_Symbol, SYMBOL_BID)
                          : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double profitPips = (posType == POSITION_TYPE_BUY)
                          ? (curPrice - openPrice) / (10.0 * _Point)
                          : (openPrice - curPrice) / (10.0 * _Point);

      //--- Only exit early if we have at least 5 pips of profit (avoids cutting winners)
      if(profitPips < 5.0) continue;

      bool exitBuy  = (posType == POSITION_TYPE_BUY  && rsi > RSI_Overbought);
      bool exitSell = (posType == POSITION_TYPE_SELL && rsi < RSI_Oversold);

      if(exitBuy || exitSell) ClosePosition(ticket);
   }
}

//+------------------------------------------------------------------+
//| Close a position by ticket                                        |
//+------------------------------------------------------------------+
void ClosePosition(ulong ticket)
{
   MqlTradeRequest req = {};
   MqlTradeResult  res = {};

   if(!PositionSelectByTicket(ticket)) return;

   req.action       = TRADE_ACTION_DEAL;
   req.position     = ticket;
   req.symbol       = _Symbol;
   req.volume       = PositionGetDouble(POSITION_VOLUME);
   req.type         = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
                      ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
   req.price        = (req.type == ORDER_TYPE_SELL)
                      ? SymbolInfoDouble(_Symbol, SYMBOL_BID)
                      : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   req.type_filling = GetFillingMode();

   if(!OrderSend(req, res))
      Print("[AureusV3_AI] Close failed: retcode=", res.retcode);
}

//+------------------------------------------------------------------+
//| Broker filling mode detection                                     |
//+------------------------------------------------------------------+
ENUM_ORDER_TYPE_FILLING GetFillingMode()
{
   long filling = SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
   if((filling & SYMBOL_FILLING_FOK) != 0) return ORDER_FILLING_FOK;
   if((filling & SYMBOL_FILLING_IOC) != 0) return ORDER_FILLING_IOC;
   return ORDER_FILLING_RETURN;
}