//═══════════════════════════════════════════════════════════════════════════════
// Framework: BREAKOUT — ATR-based channel breakout trading
// Auto-generated by Aureus AI 2026-03-15T08:12:06.395073
//═══════════════════════════════════════════════════════════════════════════════

#property strict
#property description "GBPUSD H1 Breakout EA | v0.3.0"
#property show_inputs

input int    lookback_bars         = 20;
input double atr_multiplier        = 1.5;
input int    min_breakout_pips     = 15;
input int    stop_loss_pips        = 30;
input int    take_profit_pips      = 90;
input double risk_percent          = 1.0;
input int    magic_number          = 20260400;

double high_channel, low_channel, atr_val;
int ticket = 0;

//───────────────────────────────────────────────────────────────────────────────
int OnInit() {
    return(INIT_SUCCEEDED);
}

//───────────────────────────────────────────────────────────────────────────────
void OnTick() {
    if (Bid == 0 || Ask == 0) return;

    // Find highest high and lowest low of last N bars
    high_channel = High[iHighest(Symbol(), Period(), MODE_HIGH, lookback_bars, 1)];
    low_channel  = Low[iLowest(Symbol(), Period(), MODE_LOW, lookback_bars, 1)];
    atr_val      = iATR(Symbol(), Period(), 14, 1);

    // Signals
    bool long_breakout  = (Ask > high_channel + (min_breakout_pips * Point));
    bool short_breakout = (Bid < low_channel - (min_breakout_pips * Point));

    if (PositionType() == -1) {
        if (long_breakout) OpenLong();
        if (short_breakout) OpenShort();
    } else if (PositionType() == 0 && long_breakout) {
        ClosePosition();
        OpenLong();
    } else if (PositionType() == 1 && short_breakout) {
        ClosePosition();
        OpenShort();
    }
}

//───────────────────────────────────────────────────────────────────────────────
int PositionType() {
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                return (OrderType() == OP_BUY ? 1 : 0);
            }
        }
    }
    return -1;
}

void OpenLong() {
    double lot = CalculateLotSize(stop_loss_pips);
    if (lot < 0.01) lot = 0.01;
    double sl = Bid - (stop_loss_pips * Point);
    double tp = Ask + (take_profit_pips * Point);
    ticket = OrderSend(Symbol(), OP_BUY, lot, Ask, 3, sl, tp,
                      "AureusAI Breakout Long", magic_number, 0, clrBlue);
}

void OpenShort() {
    double lot = CalculateLotSize(stop_loss_pips);
    if (lot < 0.01) lot = 0.01;
    double sl = Ask + (stop_loss_pips * Point);
    double tp = Bid - (take_profit_pips * Point);
    ticket = OrderSend(Symbol(), OP_SELL, lot, Bid, 3, sl, tp,
                      "AureusAI Breakout Short", magic_number, 0, clrRed);
}

void ClosePosition() {
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                if (OrderType() == OP_BUY) {
                    OrderClose(OrderTicket(), Bid, 3, clrWhite);
                } else {
                    OrderClose(OrderTicket(), Ask, 3, clrWhite);
                }
            }
        }
    }
}

double CalculateLotSize(int sl_pips) {
    double balance = AccountBalance();
    double risk_usd = (balance * risk_percent) / 100.0;
    double tick_value = MarketInfo(Symbol(), MODE_TICKVALUE);
    double lot = risk_usd / (sl_pips * tick_value * 10);
    return MathMax(lot, 0.01);
}

void OnDeinit(const int reason) {
}