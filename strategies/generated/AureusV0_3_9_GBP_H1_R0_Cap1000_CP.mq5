//═══════════════════════════════════════════════════════════════════════════════
// Framework: CANDLE PATTERN — Pin bar + engulfing price action
// Auto-generated by Aureus AI 2026-03-16T00:44:45.992231
//═══════════════════════════════════════════════════════════════════════════════

#property copyright "Copyright 2026, Aureus AI"
#property version   "0.3.9"

input int    ema_trend_period  = 50;
input double pin_bar_ratio     = 0.33;  // body/range ratio for pin bar
input int    stop_loss_pips    = 30;
input int    take_profit_pips  = 150;
input double risk_percent      = 0.9;
input double max_spread_pips   = 2.0;
input int    magic_number      = 20260400;

int hEMA = INVALID_HANDLE;
datetime lastBar = 0;

int OnInit() {
    hEMA = iMA(_Symbol, _Period, ema_trend_period, 0, MODE_EMA, PRICE_CLOSE);
    if (hEMA == INVALID_HANDLE) { Print("[AureusAI CP] EMA handle error"); return INIT_FAILED; }
    return INIT_SUCCEEDED;
}
void OnDeinit(const int reason) { IndicatorRelease(hEMA); }

void OnTick() {
    datetime curBar = iTime(_Symbol, _Period, 0);
    if (curBar == lastBar) return;
    lastBar = curBar;

    double spread = SymbolInfoDouble(_Symbol, SYMBOL_ASK) - SymbolInfoDouble(_Symbol, SYMBOL_BID);
    if (spread / SymbolInfoDouble(_Symbol, SYMBOL_POINT) > max_spread_pips) return;

    double emaBuf[2];
    if (CopyBuffer(hEMA, 0, 0, 2, emaBuf) < 2) return;
    double ema = emaBuf[1];

    // Previous bar OHLC
    double o1 = iOpen(_Symbol, _Period, 1),  c1 = iClose(_Symbol, _Period, 1);
    double h1 = iHigh(_Symbol, _Period, 1),  l1 = iLow(_Symbol, _Period, 1);
    double o2 = iOpen(_Symbol, _Period, 2),  c2 = iClose(_Symbol, _Period, 2);

    double range1 = h1 - l1;
    double body1  = MathAbs(c1 - o1);

    // Pin bar: small body + large wick
    bool bullPin = (range1 > 0) && (body1 / range1 < pin_bar_ratio) && (c1 > l1 + range1 * 0.6) && (c1 > ema);
    bool bearPin = (range1 > 0) && (body1 / range1 < pin_bar_ratio) && (c1 < h1 - range1 * 0.6) && (c1 < ema);

    // Bullish engulfing: current bar fully engulfs previous bearish bar
    bool bullEngulf = (c1 > o2) && (o1 < c2) && (c2 < o2) && (c1 > ema);
    bool bearEngulf = (c1 < o2) && (o1 > c2) && (c2 > o2) && (c1 < ema);

    bool longSig  = bullPin || bullEngulf;
    bool shortSig = bearPin || bearEngulf;

    int posType = GetPositionType();
    if (longSig && posType != ORDER_TYPE_BUY)  { if (posType == ORDER_TYPE_SELL) ClosePos(); OpenLong();  }
    if (shortSig && posType != ORDER_TYPE_SELL) { if (posType == ORDER_TYPE_BUY)  ClosePos(); OpenShort(); }
}

int GetPositionType() {
    if (PositionSelect(_Symbol) && (int)PositionGetInteger(POSITION_MAGIC) == magic_number)
        return (int)PositionGetInteger(POSITION_TYPE);
    return -1;
}

double CalcLot(int sl_pips) {
    double risk_usd  = AccountInfoDouble(ACCOUNT_BALANCE) * risk_percent / 100.0;
    double point     = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    double tick_val  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
    double tick_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
    double sl_val    = (sl_pips * point / tick_size) * tick_val;
    if (sl_val <= 0) return SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
    double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
    double lot  = MathFloor(risk_usd / sl_val / step) * step;
    return MathMax(MathMin(lot, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX)),
                   SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
}

void OpenLong() {
    double p = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    MqlTradeRequest req = {}; MqlTradeResult res = {};
    req.action=TRADE_ACTION_DEAL; req.symbol=_Symbol; req.volume=CalcLot(stop_loss_pips);
    req.type=ORDER_TYPE_BUY; req.price=ask;
    req.sl=ask-stop_loss_pips*p; req.tp=ask+take_profit_pips*p;
    req.magic=magic_number; req.comment="AureusAI CP Long"; req.type_filling=ORDER_FILLING_IOC;
    OrderSend(req, res);
}
void OpenShort() {
    double p = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    MqlTradeRequest req = {}; MqlTradeResult res = {};
    req.action=TRADE_ACTION_DEAL; req.symbol=_Symbol; req.volume=CalcLot(stop_loss_pips);
    req.type=ORDER_TYPE_SELL; req.price=bid;
    req.sl=bid+stop_loss_pips*p; req.tp=bid-take_profit_pips*p;
    req.magic=magic_number; req.comment="AureusAI CP Short"; req.type_filling=ORDER_FILLING_IOC;
    OrderSend(req, res);
}
void ClosePos() {
    if (!PositionSelect(_Symbol) || (int)PositionGetInteger(POSITION_MAGIC) != magic_number) return;
    ENUM_POSITION_TYPE pt = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
    MqlTradeRequest req = {}; MqlTradeResult res = {};
    req.action=TRADE_ACTION_DEAL; req.symbol=_Symbol; req.volume=PositionGetDouble(POSITION_VOLUME);
    req.type=(pt==POSITION_TYPE_BUY)?ORDER_TYPE_SELL:ORDER_TYPE_BUY;
    req.price=(pt==POSITION_TYPE_BUY)?SymbolInfoDouble(_Symbol,SYMBOL_BID):SymbolInfoDouble(_Symbol,SYMBOL_ASK);
    req.magic=magic_number; req.comment="AureusAI CP Close"; req.type_filling=ORDER_FILLING_IOC;
    OrderSend(req, res);
}