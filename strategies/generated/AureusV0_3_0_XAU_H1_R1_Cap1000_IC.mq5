// Framework: ICHIMOKU CLOUD — Cloud filtering with Kijun cross signals
// Auto-generated by Aureus AI 2026-03-15T11:23:40.086514
//═══════════════════════════════════════════════════════════════════════════════

#property strict
#property description "XAUUSD H1 Ichimoku Cloud EA | v0.3.0"
#property show_inputs

input int    tenkan_period         = 9;
input int    kijun_period          = 26;
input int    senkou_b_period       = 52;
input int    senkou_offset         = 26;
input int    stop_loss_pips        = 30;
input int    take_profit_pips      = 90;
input double risk_percent          = 1.0;
input int    magic_number          = 20260400;

double tenkan, kijun, senkou_a, senkou_b;

//───────────────────────────────────────────────────────────────────────────────
int OnInit() {
    return(INIT_SUCCEEDED);
}

//───────────────────────────────────────────────────────────────────────────────
void OnTick() {
    if (Bid == 0 || Ask == 0) return;

    // Calculate Ichimoku components
    double tenkan_high  = High[iHighest(Symbol(), Period(), MODE_HIGH, tenkan_period, 1)];
    double tenkan_low   = Low[iLowest(Symbol(), Period(), MODE_LOW, tenkan_period, 1)];
    tenkan = (tenkan_high + tenkan_low) / 2.0;

    double kijun_high   = High[iHighest(Symbol(), Period(), MODE_HIGH, kijun_period, 1)];
    double kijun_low    = Low[iLowest(Symbol(), Period(), MODE_LOW, kijun_period, 1)];
    kijun = (kijun_high + kijun_low) / 2.0;

    double senkou_b_high = High[iHighest(Symbol(), Period(), MODE_HIGH, senkou_b_period, 1)];
    double senkou_b_low  = Low[iLowest(Symbol(), Period(), MODE_LOW, senkou_b_period, 1)];
    senkou_b = (senkou_b_high + senkou_b_low) / 2.0;
    senkou_a = (tenkan + kijun) / 2.0;

    bool in_uptrend = (Close[1] > senkou_a) && (Close[1] > senkou_b);
    bool in_downtrend = (Close[1] < senkou_a) && (Close[1] < senkou_b);

    bool kijun_cross_up = (tenkan > kijun) && (tenkan < kijun); // cross signal
    bool kijun_cross_dn = (tenkan < kijun) && (tenkan > kijun);

    // Buy: uptrend + tenkan above kijun + price above cloud
    if (in_uptrend && (tenkan > kijun) && PositionType() == -1) {
        OpenLong();
    }

    // Sell: downtrend + tenkan below kijun + price below cloud
    if (in_downtrend && (tenkan < kijun) && PositionType() == -1) {
        OpenShort();
    }

    // Exit opposite
    if ((in_downtrend && tenkan < kijun) && PositionType() == 1) {
        ClosePosition();
    }
    if ((in_uptrend && tenkan > kijun) && PositionType() == 0) {
        ClosePosition();
    }
}

//───────────────────────────────────────────────────────────────────────────────
int PositionType() {
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                return (OrderType() == OP_BUY ? 1 : 0);
            }
        }
    }
    return -1;
}

void OpenLong() {
    double lot = CalculateLotSize(stop_loss_pips);
    if (lot < 0.01) lot = 0.01;
    double sl = Bid - (stop_loss_pips * Point);
    double tp = Ask + (take_profit_pips * Point);
    OrderSend(Symbol(), OP_BUY, lot, Ask, 3, sl, tp,
             "AureusAI Ichimoku Long", magic_number, 0, clrBlue);
}

void OpenShort() {
    double lot = CalculateLotSize(stop_loss_pips);
    if (lot < 0.01) lot = 0.01;
    double sl = Ask + (stop_loss_pips * Point);
    double tp = Bid - (take_profit_pips * Point);
    OrderSend(Symbol(), OP_SELL, lot, Bid, 3, sl, tp,
             "AureusAI Ichimoku Short", magic_number, 0, clrRed);
}

void ClosePosition() {
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                if (OrderType() == OP_BUY) {
                    OrderClose(OrderTicket(), Bid, 3, clrWhite);
                } else {
                    OrderClose(OrderTicket(), Ask, 3, clrWhite);
                }
            }
        }
    }
}

double CalculateLotSize(int sl_pips) {
    double balance = AccountBalance();
    double risk_usd = (balance * risk_percent) / 100.0;
    double tick_value = MarketInfo(Symbol(), MODE_TICKVALUE);
    double lot = risk_usd / (sl_pips * tick_value * 10);
    return MathMax(lot, 0.01);
}

void OnDeinit(const int reason) {
}