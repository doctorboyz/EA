//+------------------------------------------------------------------+
//| XAUBreakout.mq5                                                  |
//| Framework: ATR-Channel Breakout — tuned for XAUUSD              |
//| Generated by Aureus AI v0.3.5        |
//| 2026-03-16T07:37:53.858733                                 |
//+------------------------------------------------------------------+
#property copyright "Copyright 2026, Aureus AI"
#property version   "0.3.5"
#property strict

//--- Inputs: Identity
input int    MagicNumber      = 20260400;

//--- Inputs: Risk (NEVER fixed USD — always percentage)
input double RiskPercent      = 1.0;   // % balance per trade

//--- Inputs: Breakout Channel
input int    ChannelBars      = 100;    // N-bar high/low channel
input int    ATR_Period       = 14;    // ATR smoothing period

//--- Inputs: ATR-based SL/TP (no fixed pips — adaptive to XAUUSD volatility)
input double ATR_SL_Mult      = 1.5;  // SL = ATR * this
input double ATR_TP_Mult      = 3.5;                                       // TP = ATR * this → ~2.3:1 R/R
input double MinATRExpansion  = 1.1;   // Breakout needs expanding volatility (ATR > baseline * this)

//--- Inputs: Session Filter (trade London + NY only, UTC)
input bool   UseSessionFilter = true;
input int    SessionStartHour = 7;     // UTC 07:00 = London open
input int    SessionEndHour   = 17;    // UTC 17:00 = NY close

//--- Inputs: Spread guard (XAUUSD spread ~10-50 pts normally)
input double MaxSpreadPts     = 2.0;    // Skip if wider

//--- Global state
int      hATR        = INVALID_HANDLE;
double   atrBaseline = 0.0;
datetime lastBar     = 0;

//+------------------------------------------------------------------+
//| Expert initialization                                             |
//+------------------------------------------------------------------+
int OnInit()
{
   hATR = iATR(_Symbol, _Period, ATR_Period);
   if(hATR == INVALID_HANDLE)
   {
      Print("[XAUBreakout] ERROR: failed to create ATR handle");
      return INIT_FAILED;
   }
   Print("[XAUBreakout] v0.3.5 | Risk=", RiskPercent,
         "% | Channel=", ChannelBars, " bars | SL=", ATR_SL_Mult,
         "x ATR  TP=", ATR_TP_Mult, "x ATR");
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| Expert deinitialization                                           |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   IndicatorRelease(hATR);
   Comment("");
}

//+------------------------------------------------------------------+
//| Main tick handler                                                 |
//+------------------------------------------------------------------+
void OnTick()
{
   //--- New bar guard (execute logic once per closed bar)
   datetime curBar = iTime(_Symbol, _Period, 0);
   if(curBar == lastBar) return;
   lastBar = curBar;

   //--- Session filter
   if(UseSessionFilter)
   {
      MqlDateTime dt;
      TimeToStruct(TimeCurrent(), dt);
      if(dt.hour < SessionStartHour || dt.hour >= SessionEndHour)
      {
         Comment("[XAUBreakout] Outside session (", dt.hour, ":xx UTC) — waiting");
         return;
      }
   }

   //--- Spread filter
   long spreadLong = SymbolInfoInteger(_Symbol, SYMBOL_SPREAD);
   if((double)spreadLong > MaxSpreadPts) return;

   //--- ATR
   double atrBuf[3];
   ArraySetAsSeries(atrBuf, true);
   if(CopyBuffer(hATR, 0, 0, 3, atrBuf) < 3) return;
   double atr = atrBuf[1];
   if(atr <= 0.0) return;

   //--- Rolling ATR baseline (10-bar EMA of ATR)
   if(atrBaseline <= 0.0) atrBaseline = atr;
   atrBaseline = (atrBaseline * 9.0 + atr) / 10.0;

   //--- Manage any open positions first (breakeven + trail)
   ManagePositions(atr);

   //--- No new entry if already in a position
   if(GetPositionType() >= 0) return;

   //--- ATR expansion guard: breakout must coincide with rising volatility
   if(atr < atrBaseline * MinATRExpansion) return;

   //--- Channel: highest high / lowest low over last ChannelBars closed bars
   int hiIdx = iHighest(_Symbol, _Period, MODE_HIGH, ChannelBars, 1);
   int loIdx = iLowest(_Symbol, _Period,  MODE_LOW,  ChannelBars, 1);
   if(hiIdx < 0 || loIdx < 0) return;

   double channelHigh = iHigh(_Symbol, _Period, hiIdx);
   double channelLow  = iLow(_Symbol,  _Period, loIdx);
   double prevClose   = iClose(_Symbol, _Period, 1);

   //--- Dashboard
   Comment("=== XAUBreakout ===\n"
           "Channel H: ", DoubleToString(channelHigh, _Digits), "\n"
           "Channel L: ", DoubleToString(channelLow,  _Digits), "\n"
           "ATR: ",       DoubleToString(atr,          _Digits),
           "  Baseline: ", DoubleToString(atrBaseline, _Digits), "\n"
           "Spread: ",    (string)spreadLong, " pts");

   //--- Entry signals
   if(prevClose > channelHigh)      OpenTrade(ORDER_TYPE_BUY,  atr);
   else if(prevClose < channelLow)  OpenTrade(ORDER_TYPE_SELL, atr);
}

//+------------------------------------------------------------------+
//| Return position type for this EA's magic, or -1 if none          |
//+------------------------------------------------------------------+
int GetPositionType()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)     continue;
      return (int)PositionGetInteger(POSITION_TYPE);
   }
   return -1;
}

//+------------------------------------------------------------------+
//| Percentage-based lot sizing using ATR stop distance              |
//| NEVER fixed USD risk — V4 failure guard                          |
//+------------------------------------------------------------------+
double CalcLot(double sl_dist)
{
   double balance  = AccountInfoDouble(ACCOUNT_BALANCE);
   double risk_usd = balance * RiskPercent / 100.0;
   double tickVal  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);

   if(tickSize <= 0.0 || sl_dist <= 0.0)
      return SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);

   double slUSD = (sl_dist / tickSize) * tickVal;
   if(slUSD <= 0.0) return SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);

   double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   double minL = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxL = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);

   double lot = MathFloor(risk_usd / slUSD / step) * step;
   lot = MathMax(minL, MathMin(maxL, lot));

   //--- Final margin sanity check
   double marginNeeded = 0.0;
   if(!OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, lot,
                       SymbolInfoDouble(_Symbol, SYMBOL_ASK), marginNeeded)
      || marginNeeded > AccountInfoDouble(ACCOUNT_MARGIN_FREE))
      return 0.0;

   return lot;
}

//+------------------------------------------------------------------+
//| Broker filling mode detection                                     |
//+------------------------------------------------------------------+
ENUM_ORDER_TYPE_FILLING GetFillingMode()
{
   long filling = SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
   if((filling & SYMBOL_FILLING_FOK) != 0) return ORDER_FILLING_FOK;
   if((filling & SYMBOL_FILLING_IOC) != 0) return ORDER_FILLING_IOC;
   return ORDER_FILLING_RETURN;
}

//+------------------------------------------------------------------+
//| Open a market order with ATR-based SL/TP                         |
//+------------------------------------------------------------------+
void OpenTrade(ENUM_ORDER_TYPE otype, double atr)
{
   double slDist = atr * ATR_SL_Mult;
   double tpDist = atr * ATR_TP_Mult;
   double lot    = CalcLot(slDist);

   if(lot <= 0.0)
   {
      Print("[XAUBreakout] Lot=0 — skipping (margin insufficient?)");
      return;
   }

   MqlTradeRequest req = {};
   MqlTradeResult  res = {};

   req.action       = TRADE_ACTION_DEAL;
   req.symbol       = _Symbol;
   req.volume       = lot;
   req.magic        = MagicNumber;
   req.type         = otype;
   req.deviation    = 15;
   req.type_filling = GetFillingMode();
   req.comment      = "XAUBreakout";

   if(otype == ORDER_TYPE_BUY)
   {
      req.price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      req.sl    = NormalizeDouble(req.price - slDist, _Digits);
      req.tp    = NormalizeDouble(req.price + tpDist, _Digits);
   }
   else
   {
      req.price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      req.sl    = NormalizeDouble(req.price + slDist, _Digits);
      req.tp    = NormalizeDouble(req.price - tpDist, _Digits);
   }

   if(!OrderSend(req, res))
      Print("[XAUBreakout] Trade FAILED: retcode=", res.retcode,
            " type=", EnumToString(otype), " lot=", lot,
            " sl=", req.sl, " tp=", req.tp);
   else
      Print("[XAUBreakout] OPEN ", EnumToString(otype),
            " lot=", DoubleToString(lot, 2),
            " sl=", DoubleToString(req.sl, _Digits),
            " tp=", DoubleToString(req.tp, _Digits),
            " atr=", DoubleToString(atr, _Digits));
}

//+------------------------------------------------------------------+
//| Manage open positions: breakeven + ATR trailing stop             |
//+------------------------------------------------------------------+
void ManagePositions(double atr)
{
   double stopLevel   = (double)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL) * _Point;
   double freezeLevel = (double)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL) * _Point;
   double beDist      = atr * ATR_SL_Mult;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket))                              continue;
      if(PositionGetInteger(POSITION_MAGIC) != MagicNumber)           continue;
      if(PositionGetString(POSITION_SYMBOL)  != _Symbol)              continue;

      ENUM_POSITION_TYPE pt        = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      double             openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
      double             curSL     = PositionGetDouble(POSITION_SL);
      double             curTP     = PositionGetDouble(POSITION_TP);
      double             bid       = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double             ask       = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double             newSL     = curSL;
      bool               doModify  = false;

      //--- Skip if near freeze level
      if(pt == POSITION_TYPE_BUY  && MathAbs(bid - curTP) <= freezeLevel) continue;
      if(pt == POSITION_TYPE_SELL && MathAbs(ask - curTP) <= freezeLevel) continue;

      if(pt == POSITION_TYPE_BUY)
      {
         //--- Breakeven: when profit >= 1x ATR_SL_Mult distance
         if(bid >= openPrice + beDist && curSL < openPrice - _Point)
            newSL = NormalizeDouble(openPrice + _Point, _Digits);

         //--- Trail: follow price at ATR_SL_Mult distance
         double trail = NormalizeDouble(bid - beDist, _Digits);
         if(trail > newSL + _Point) newSL = trail;

         if(newSL > curSL + _Point && bid > newSL + stopLevel) doModify = true;
      }
      else // SELL
      {
         //--- Breakeven
         if(ask <= openPrice - beDist && (curSL > openPrice + _Point || curSL == 0.0))
            newSL = NormalizeDouble(openPrice - _Point, _Digits);

         //--- Trail
         double trail = NormalizeDouble(ask + beDist, _Digits);
         if(trail < newSL - _Point || newSL == 0.0) newSL = trail;

         if((newSL < curSL - _Point || curSL == 0.0) && ask < newSL - stopLevel) doModify = true;
      }

      if(doModify)
      {
         MqlTradeRequest req = {};
         MqlTradeResult  res = {};
         req.action   = TRADE_ACTION_SLTP;
         req.position = ticket;
         req.symbol   = _Symbol;
         req.sl       = newSL;
         req.tp       = curTP;
         OrderSend(req, res);
      }
   }
}