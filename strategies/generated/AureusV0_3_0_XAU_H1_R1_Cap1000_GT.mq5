//═══════════════════════════════════════════════════════════════════════════════
// Framework: GRID TRADING — Multiple entry levels in grid pattern
// Auto-generated by Aureus AI 2026-03-15T08:06:35.398515
//═══════════════════════════════════════════════════════════════════════════════

#property strict
#property description "XAUUSD H1 Grid Trading EA | v0.3.0"
#property show_inputs

input double grid_level_spacing    = 20;  // pips
input int    max_grid_levels       = 5;
input double base_lot_size         = 0.1;
input double lot_multiplier        = 1.2;     // increase per level
input int    take_profit_grid      = 40;   // close when profit
input double risk_percent          = 1.0;
input int    magic_number          = 20260400;

int grid_buys = 0, grid_sells = 0;

//───────────────────────────────────────────────────────────────────────────────
int OnInit() {
    return(INIT_SUCCEEDED);
}

//───────────────────────────────────────────────────────────────────────────────
void OnTick() {
    if (Bid == 0 || Ask == 0) return;

    // Count existing grid positions
    grid_buys = 0;
    grid_sells = 0;
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                if (OrderType() == OP_BUY) grid_buys++;
                else grid_sells++;
            }
        }
    }

    // Add more buy levels
    if (grid_buys < max_grid_levels) {
        double next_buy_price = Ask - (grid_buys * grid_level_spacing * Point);
        if (Bid <= next_buy_price) {
            double lot = base_lot_size * MathPow(lot_multiplier, grid_buys);
            OrderSend(Symbol(), OP_BUY, lot, Ask, 3, 0, 0,
                     "Grid Buy L" + grid_buys, magic_number, 0, clrBlue);
        }
    }

    // Add more sell levels
    if (grid_sells < max_grid_levels) {
        double next_sell_price = Bid + (grid_sells * grid_level_spacing * Point);
        if (Ask >= next_sell_price) {
            double lot = base_lot_size * MathPow(lot_multiplier, grid_sells);
            OrderSend(Symbol(), OP_SELL, lot, Bid, 3, 0, 0,
                     "Grid Sell L" + grid_sells, magic_number, 0, clrRed);
        }
    }

    // Close profitable orders
    double total_profit = GetGridProfit();
    if (total_profit > (AccountBalance() * take_profit_grid / 100.0)) {
        CloseAllGrid();
    }
}

//───────────────────────────────────────────────────────────────────────────────
double GetGridProfit() {
    double profit = 0;
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                profit += OrderProfit();
            }
        }
    }
    return profit;
}

void CloseAllGrid() {
    for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if (OrderMagicNumber() == magic_number && OrderSymbol() == Symbol()) {
                if (OrderType() == OP_BUY) {
                    OrderClose(OrderTicket(), Bid, 3, clrWhite);
                } else {
                    OrderClose(OrderTicket(), Ask, 3, clrWhite);
                }
            }
        }
    }
}

void OnDeinit(const int reason) {
}