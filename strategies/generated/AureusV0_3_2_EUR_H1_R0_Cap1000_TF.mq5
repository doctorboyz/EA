//═══════════════════════════════════════════════════════════════════════════════
// Framework: TREND FOLLOWING — EMA crossover + RSI filter
// Auto-generated by Aureus AI 2026-03-16T04:11:12.881725
//═══════════════════════════════════════════════════════════════════════════════

#property copyright "Copyright 2026, Aureus AI"
#property version   "0.3.2"

//--- Inputs
input int    ema_fast_period   = 50;
input int    ema_slow_period   = 200;
input double rsi_oversold      = 30.0;
input double rsi_overbought    = 70.0;
input int    stop_loss_pips    = 30;
input int    take_profit_pips  = 120;
input double risk_percent      = 0.8;
input double max_spread_pips   = 2.0;
input int    magic_number      = 20260400;

//--- Handles
int hFastEMA = INVALID_HANDLE;
int hSlowEMA = INVALID_HANDLE;
int hRSI     = INVALID_HANDLE;

datetime lastBar = 0;

//─────────────────────────────────────────────────────────────────────────────
int OnInit() {
    hFastEMA = iMA(_Symbol, _Period, ema_fast_period, 0, MODE_EMA, PRICE_CLOSE);
    hSlowEMA = iMA(_Symbol, _Period, ema_slow_period, 0, MODE_EMA, PRICE_CLOSE);
    hRSI     = iRSI(_Symbol, _Period, 14, PRICE_CLOSE);
    if (hFastEMA == INVALID_HANDLE || hSlowEMA == INVALID_HANDLE || hRSI == INVALID_HANDLE) {
        Print("[AureusAI] ERROR: Indicator handle creation failed");
        return INIT_FAILED;
    }
    return INIT_SUCCEEDED;
}

void OnDeinit(const int reason) {
    IndicatorRelease(hFastEMA);
    IndicatorRelease(hSlowEMA);
    IndicatorRelease(hRSI);
}

//─────────────────────────────────────────────────────────────────────────────
void OnTick() {
    // One bar per trade check
    datetime curBar = iTime(_Symbol, _Period, 0);
    if (curBar == lastBar) return;
    lastBar = curBar;

    // Spread filter
    double spread = SymbolInfoDouble(_Symbol, SYMBOL_ASK) - SymbolInfoDouble(_Symbol, SYMBOL_BID);
    double point  = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    if (spread / point > max_spread_pips) return;

    // Read indicators
    double fastBuf[2], slowBuf[2], rsiBuf[2];
    if (CopyBuffer(hFastEMA, 0, 0, 2, fastBuf) < 2) return;
    if (CopyBuffer(hSlowEMA, 0, 0, 2, slowBuf) < 2) return;
    if (CopyBuffer(hRSI,     0, 0, 2, rsiBuf)  < 2) return;

    double fastEMA = fastBuf[1];
    double slowEMA = slowBuf[1];
    double rsi     = rsiBuf[1];

    bool longSig  = (fastEMA > slowEMA) && (rsi < rsi_oversold);
    bool shortSig = (fastEMA < slowEMA) && (rsi > rsi_overbought);

    int posType = GetPositionType();

    if (longSig && posType != ORDER_TYPE_BUY) {
        if (posType == ORDER_TYPE_SELL) ClosePosition();
        OpenLong();
    } else if (shortSig && posType != ORDER_TYPE_SELL) {
        if (posType == ORDER_TYPE_BUY) ClosePosition();
        OpenShort();
    }
}

//─────────────────────────────────────────────────────────────────────────────
// Helpers
//─────────────────────────────────────────────────────────────────────────────

int GetPositionType() {
    if (PositionSelect(_Symbol)) {
        if ((int)PositionGetInteger(POSITION_MAGIC) == magic_number)
            return (int)PositionGetInteger(POSITION_TYPE);
    }
    return -1;
}

double CalcLot(int sl_pips) {
    double balance   = AccountInfoDouble(ACCOUNT_BALANCE);
    double risk_usd  = balance * risk_percent / 100.0;
    double tick_val  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
    double tick_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
    double point     = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    double sl_val    = (sl_pips * point / tick_size) * tick_val;
    if (sl_val <= 0) return 0.01;
    double lot = risk_usd / sl_val;
    double minLot  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
    double maxLot  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
    double stepLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
    lot = MathFloor(lot / stepLot) * stepLot;
    return MathMax(MathMin(lot, maxLot), minLot);
}

void OpenLong() {
    double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    double ask   = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    double lot   = CalcLot(stop_loss_pips);

    MqlTradeRequest req = {};
    MqlTradeResult  res = {};
    req.action    = TRADE_ACTION_DEAL;
    req.symbol    = _Symbol;
    req.volume    = lot;
    req.type      = ORDER_TYPE_BUY;
    req.price     = ask;
    req.sl        = ask - stop_loss_pips   * point;
    req.tp        = ask + take_profit_pips * point;
    req.magic     = magic_number;
    req.comment   = "AureusAI TF Long";
    req.type_filling = ORDER_FILLING_IOC;
    OrderSend(req, res);
}

void OpenShort() {
    double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
    double bid   = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    double lot   = CalcLot(stop_loss_pips);

    MqlTradeRequest req = {};
    MqlTradeResult  res = {};
    req.action    = TRADE_ACTION_DEAL;
    req.symbol    = _Symbol;
    req.volume    = lot;
    req.type      = ORDER_TYPE_SELL;
    req.price     = bid;
    req.sl        = bid + stop_loss_pips   * point;
    req.tp        = bid - take_profit_pips * point;
    req.magic     = magic_number;
    req.comment   = "AureusAI TF Short";
    req.type_filling = ORDER_FILLING_IOC;
    OrderSend(req, res);
}

void ClosePosition() {
    if (!PositionSelect(_Symbol)) return;
    if ((int)PositionGetInteger(POSITION_MAGIC) != magic_number) return;

    ENUM_POSITION_TYPE pType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
    double vol = PositionGetDouble(POSITION_VOLUME);
    double price = (pType == POSITION_TYPE_BUY)
                   ? SymbolInfoDouble(_Symbol, SYMBOL_BID)
                   : SymbolInfoDouble(_Symbol, SYMBOL_ASK);

    MqlTradeRequest req = {};
    MqlTradeResult  res = {};
    req.action   = TRADE_ACTION_DEAL;
    req.symbol   = _Symbol;
    req.volume   = vol;
    req.type     = (pType == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
    req.price    = price;
    req.magic    = magic_number;
    req.comment  = "AureusAI TF Close";
    req.type_filling = ORDER_FILLING_IOC;
    OrderSend(req, res);
}