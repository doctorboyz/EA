//═══════════════════════════════════════════════════════════════════════════════
// Framework: SNIPER ENTRY — High-precision entries, max 2 trades/day
// Auto-generated by Aureus AI 2026-03-16T00:16:53.136669
//═══════════════════════════════════════════════════════════════════════════════

#property copyright "Copyright 2026, Aureus AI"
#property version   "0.3.1"

input int    ema_period        = 200;
input int    rsi_period        = 14;
input double rsi_oversold      = 28.0;
input double rsi_overbought    = 70.0;
input int    atr_period        = 14;
input double atr_sl_mult       = 1.5;
input double atr_tp_mult       = 3.0;
input double risk_percent      = 1.0;
input double max_spread_pips   = 2.0;
input int    max_trades_day    = 2;
input int    magic_number      = 20260400;

int hEMA = INVALID_HANDLE, hRSI = INVALID_HANDLE, hATR = INVALID_HANDLE;
datetime lastBar = 0;
datetime todayStart = 0;
int tradesToday = 0;

int OnInit() {
    hEMA = iMA(_Symbol, _Period, ema_period, 0, MODE_EMA, PRICE_CLOSE);
    hRSI = iRSI(_Symbol, _Period, rsi_period, PRICE_CLOSE);
    hATR = iATR(_Symbol, _Period, atr_period);
    if (hEMA == INVALID_HANDLE || hRSI == INVALID_HANDLE || hATR == INVALID_HANDLE) {
        Print("[AureusAI SE] Handle error"); return INIT_FAILED;
    }
    return INIT_SUCCEEDED;
}
void OnDeinit(const int reason) {
    IndicatorRelease(hEMA); IndicatorRelease(hRSI); IndicatorRelease(hATR);
}

void OnTick() {
    datetime curBar = iTime(_Symbol, _Period, 0);
    if (curBar == lastBar) return;
    lastBar = curBar;

    // Reset daily trade count
    MqlDateTime dt; TimeToStruct(TimeCurrent(), dt);
    datetime today = StringToTime(StringFormat("%04d.%02d.%02d 00:00", dt.year, dt.mon, dt.day));
    if (today != todayStart) { todayStart = today; tradesToday = 0; }
    if (tradesToday >= max_trades_day) return;

    double spread = SymbolInfoDouble(_Symbol, SYMBOL_ASK) - SymbolInfoDouble(_Symbol, SYMBOL_BID);
    if (spread / SymbolInfoDouble(_Symbol, SYMBOL_POINT) > max_spread_pips) return;

    double emaBuf[2], rsiBuf[2], atrBuf[2];
    if (CopyBuffer(hEMA, 0, 0, 2, emaBuf) < 2) return;
    if (CopyBuffer(hRSI, 0, 0, 2, rsiBuf) < 2) return;
    if (CopyBuffer(hATR, 0, 0, 2, atrBuf) < 2) return;

    double ema = emaBuf[1], rsi = rsiBuf[1], atr = atrBuf[1];
    double close1 = iClose(_Symbol, _Period, 1);

    // Sniper: price near EMA + RSI extreme + strong momentum
    bool longSig  = (close1 > ema) && (rsi < rsi_oversold)  && (close1 > iClose(_Symbol, _Period, 2));
    bool shortSig = (close1 < ema) && (rsi > rsi_overbought) && (close1 < iClose(_Symbol, _Period, 2));

    int posType = GetPositionType();
    if (longSig && posType == -1)  { OpenLong(atr);  tradesToday++; }
    if (shortSig && posType == -1) { OpenShort(atr); tradesToday++; }
}

int GetPositionType() {
    if (PositionSelect(_Symbol) && (int)PositionGetInteger(POSITION_MAGIC) == magic_number)
        return (int)PositionGetInteger(POSITION_TYPE);
    return -1;
}

double CalcLot(double sl_price_dist) {
    double risk_usd  = AccountInfoDouble(ACCOUNT_BALANCE) * risk_percent / 100.0;
    double tick_val  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
    double tick_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
    double sl_val    = (sl_price_dist / tick_size) * tick_val;
    if (sl_val <= 0) return SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
    double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
    double lot  = MathFloor(risk_usd / sl_val / step) * step;
    return MathMax(MathMin(lot, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX)),
                   SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
}

void OpenLong(double atr) {
    double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    double sl  = ask - atr * atr_sl_mult;
    double tp  = ask + atr * atr_tp_mult;
    MqlTradeRequest req = {}; MqlTradeResult res = {};
    req.action=TRADE_ACTION_DEAL; req.symbol=_Symbol; req.volume=CalcLot(atr*atr_sl_mult);
    req.type=ORDER_TYPE_BUY; req.price=ask; req.sl=sl; req.tp=tp;
    req.magic=magic_number; req.comment="AureusAI SE Long"; req.type_filling=ORDER_FILLING_IOC;
    OrderSend(req, res);
}
void OpenShort(double atr) {
    double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    double sl  = bid + atr * atr_sl_mult;
    double tp  = bid - atr * atr_tp_mult;
    MqlTradeRequest req = {}; MqlTradeResult res = {};
    req.action=TRADE_ACTION_DEAL; req.symbol=_Symbol; req.volume=CalcLot(atr*atr_sl_mult);
    req.type=ORDER_TYPE_SELL; req.price=bid; req.sl=sl; req.tp=tp;
    req.magic=magic_number; req.comment="AureusAI SE Short"; req.type_filling=ORDER_FILLING_IOC;
    OrderSend(req, res);
}